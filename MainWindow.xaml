<Window x:Class="WebViewHub.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WebViewHub"
        xmlns:controls="clr-namespace:WebViewHub.Controls"
        Title="WebViewHub"
        Icon="pack://application:,,,/app.ico"
        Height="900"
        Width="1600"
        Background="#f5f5f7"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        Closing="Window_Closing">
    
    <Window.Resources>
        <!-- 主要按钮 - 蓝色 -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#007AFF"/>
            <Setter Property="Foreground" Value="#ffffff"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#0066cc"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#0055b3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 次要按钮 - 灰色 -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#ffffff"/>
            <Setter Property="Foreground" Value="#1d1d1f"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#e5e5e7"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#f5f5f7"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#e8e8ed"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 小按钮 - 图标按钮 -->
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#86868b"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#e5e5e7"/>
                                <Setter Property="Foreground" Value="#1d1d1f"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#d1d1d6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- WebView 容器样式 -->
        <Style x:Key="WebViewContainerStyle" TargetType="Border">
            <Setter Property="Background" Value="#ffffff"/>
            <Setter Property="BorderBrush" Value="#e5e5e7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" Opacity="0.08" BlurRadius="20" ShadowDepth="0"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶部工具栏 -->
        <Border Grid.Row="0"
                Background="#ffffff"
                BorderBrush="#e5e5e7"
                BorderThickness="0,0,0,1"
                Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 左侧：标题和副标题 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="WebViewHub"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#1d1d1f"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="多开浏览器"
                               FontSize="12"
                               Foreground="#86868b"
                               Margin="8,0,0,0"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- 中间：布局方案 -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Button Content="2×2"
                            Style="{StaticResource SecondaryButton}"
                            Click="ApplyLayout2x2_Click"
                            Margin="0,0,4,0"
                            ToolTip="2×2网格布局"/>
                    <Button Content="3×3"
                            Style="{StaticResource SecondaryButton}"
                            Click="ApplyLayout3x3_Click"
                            Margin="0,0,4,0"
                            ToolTip="3×3网格布局"/>
                    <Button Content="左右"
                            Style="{StaticResource SecondaryButton}"
                            Click="ApplyLayoutSplitVertical_Click"
                            Margin="0,0,4,0"
                            ToolTip="左右分栏"/>
                    <Button Content="上下"
                            Style="{StaticResource SecondaryButton}"
                            Click="ApplyLayoutSplitHorizontal_Click"
                            Margin="0,0,4,0"
                            ToolTip="上下分栏"/>
                    <Button Content="瀑布"
                            Style="{StaticResource SecondaryButton}"
                            Click="ApplyLayoutWaterfall_Click"
                            ToolTip="瀑布流布局"/>
                </StackPanel>

                <!-- 右侧：操作按钮和计数 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="保存"
                            Style="{StaticResource IconButton}"
                            Click="SaveLayout_Click"
                            Margin="0,0,8,0"/>
                    <Button Content="+ 新建"
                            Style="{StaticResource PrimaryButton}"
                            Click="AddWebView_Click"
                            Margin="0,0,12,0"/>
                    <Border Background="#f5f5f7"
                            CornerRadius="4"
                            Padding="10,6"
                            BorderBrush="#e5e5e7"
                            BorderThickness="1">
                        <TextBlock x:Name="CountText"
                                   Text="0/10"
                                   FontSize="12"
                                   Foreground="#86868b"
                                   FontWeight="Medium"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 核心工作区：画布铺满，调度台悬浮居中 -->
        <Border Grid.Row="1"
                Background="#f5f5f7"
                Padding="0">
            <Grid>
                <!-- 全屏画布 -->
                <Canvas x:Name="LayoutCanvas"
                        ClipToBounds="True"
                        Background="#f5f5f7"
                        Margin="4"/>

                <!-- 调度台：自适应内容宽度，居中浮动不会遮挡网页 -->
                <Border HorizontalAlignment="Center"
                        VerticalAlignment="Stretch"
                        Margin="0,8,0,8"
                        CornerRadius="14"
                        Background="#ffffffee"
                        BorderBrush="#e5e5e7"
                        BorderThickness="1"
                        Panel.ZIndex="10">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" Opacity="0.12" BlurRadius="30" ShadowDepth="0"/>
                    </Border.Effect>
                    <controls:CentralCommandPanel x:Name="CommandPanel"/>
                </Border>

            </Grid>
        </Border>
    </Grid>
</Window>
