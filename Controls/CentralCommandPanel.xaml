<UserControl x:Class="WebViewHub.Controls.CentralCommandPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:WebViewHub.Controls"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             Background="#ffffff">

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- 左侧主面板固定 340 宽 -->
            <ColumnDefinition Width="340"/>
            <!-- 侧边栏列设置为 Auto，让内部 Border 控制宽度从而自适应伸缩 -->
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- 右侧：垂直标签通知栏 -->
        <Border x:Name="SidebarContainer" Grid.Column="1" Width="100" Background="#f8f8f8" BorderBrush="#e5e5e7" BorderThickness="1,0,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <Grid Margin="0,12,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- 展开折叠按钮 -->
                    <Button x:Name="ToggleSidebarButton" Grid.Column="0" Content="☰" FontSize="14" Foreground="#1d1d1f" Background="Transparent" 
                            BorderThickness="0" Cursor="Hand" Padding="8,4" Margin="4,0,0,0"
                            Click="ToggleSidebarButton_Click" ToolTip="折叠/展开通知栏">
                        <Button.Resources>
                            <Style TargetType="{x:Type Border}">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    
                    <!-- 标题栏字样 (只有展开时显示) -->
                    <TextBlock x:Name="SidebarTitle" Grid.Column="1" Text="通知管理" FontSize="13" FontWeight="SemiBold" 
                               Foreground="#1d1d1f" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="-6,0,12,0"/>
                </Grid>
                
                <!-- 垂直滚动的标签列表 -->
                <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" Margin="6,0,6,8">
                    <StackPanel x:Name="RoleTabsPanel" Orientation="Vertical"/>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- 左侧：调度台主内容区，宽度锁定 340px，占据主要固定空间 -->
        <Grid Grid.Column="0" Width="340">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="2*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="1*"/>
            </Grid.RowDefinitions>

            <!-- 顶部标题区：左为标题文字，右为清空按钮 -->
            <Border Grid.Row="0" BorderBrush="#e5e5e7" BorderThickness="0,0,0,1" Padding="15,10,15,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 左侧标题 -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="AI 中央调度台" FontSize="14" FontWeight="SemiBold" Foreground="#1d1d1f"/>
                        <TextBlock Text="提取回复 / 分发指令 (@角色)" FontSize="11" Foreground="#86868b" Margin="0,2,0,0"/>
                    </StackPanel>

                    <!-- 清空按钮 -->
                    <Button Grid.Column="1" x:Name="ClearResponsesButton" Content="清空" Click="ClearResponsesButton_Click"
                            Padding="7,3" FontSize="11" Foreground="#86868b" Background="Transparent"
                            BorderBrush="#e5e5e7" BorderThickness="1" Cursor="Hand" VerticalAlignment="Center" Margin="6,0,0,0">
                        <Button.Resources>
                            <Style TargetType="{x:Type Border}">
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>
            </Border>

            <!-- 上半部分：中转信息看板区域 -->
            <Border Grid.Row="1" Background="#fdfdfd" Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- WebView 上方不再需要额外标签栏（已移入标题区右侧）-->

                <!-- 多卡片回复展示区 (纯原生 Edge WebView 渲染内核) -->
                <Border Grid.Row="1" CornerRadius="8" BorderBrush="#e5e5e7" BorderThickness="1" Background="#ffffff" Margin="0,0,0,8" ClipToBounds="True">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" Opacity="0.04" BlurRadius="6" ShadowDepth="1"/>
                    </Border.Effect>
                    <wv2:WebView2 x:Name="ResponseBoardWebView" DefaultBackgroundColor="White" Margin="0"/>
                </Border>

                <!-- 抓取按钮 -->
                <Button Grid.Row="2" x:Name="FetchButton" Content="⬇ 抓取所有 AI 的最新回答"
                        Margin="0,8,0,0" Padding="10,8"
                        Background="#f0f7ff" Foreground="#0284c7"
                        BorderBrush="#bae0ff" BorderThickness="1"
                        FontWeight="SemiBold"
                        Cursor="Hand" Click="FetchButton_Click">
                    <Button.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Border>


        <!-- 分界线 -->
        <Border Grid.Row="2" Height="1" Background="#e5e5e7"/>

        <!-- 下半部分：提问与发号施令区 -->
        <Border Grid.Row="3" Background="#ffffff" Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <TextBlock Grid.Row="0" Text="调度指令 (如: @豆包 帮我写...)" FontSize="12" Foreground="#86868b" Margin="0,0,0,8"/>
                
                <!-- 发送输入区 -->
                <Border Grid.Row="1" BorderBrush="#d1d1d6" BorderThickness="1" CornerRadius="6">
                    <RichTextBox x:Name="CommandInput" 
                                     VerticalScrollBarVisibility="Auto"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     FontSize="14"
                                     Padding="10,12"
                                     Foreground="#333333"
                                     TextChanged="CommandInput_TextChanged"
                                     PreviewKeyDown="CommandInput_PreviewKeyDown">
                            <FlowDocument>
                                <Paragraph Margin="0"></Paragraph>
                            </FlowDocument>
                        </RichTextBox>
                </Border>
                
                <!-- @符号下拉菜单容器 -->
                <Popup x:Name="RoleTagPopup" PlacementTarget="{Binding ElementName=CommandInput}" Placement="Top" StaysOpen="False" AllowsTransparency="True">
                    <Border Background="#ffffff" BorderBrush="#e5e5e7" BorderThickness="1" CornerRadius="6" Margin="0,0,0,4" Effect="{DynamicResource DropShadowEffect}">
                        <Border.Resources>
                            <DropShadowEffect x:Key="DropShadowEffect" Color="#000000" Opacity="0.1" BlurRadius="10" ShadowDepth="2"/>
                        </Border.Resources>
                        <ListBox x:Name="RoleTagListBox" Background="Transparent" BorderThickness="0" 
                                 MaxHeight="150" MinWidth="150" Margin="4"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 SelectionMode="Single"
                                 PreviewMouseLeftButtonUp="RoleTagListBox_PreviewMouseLeftButtonUp">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="8,6"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border Name="Border" Padding="{TemplateBinding Padding}" CornerRadius="4" Background="Transparent">
                                                    <ContentPresenter />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Border" Property="Background" Value="#f5f5f7"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="Border" Property="Background" Value="#e8e8ed"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                    </Border>
                </Popup>
                
                <!-- 发送按钮 -->
                <Button Grid.Row="2" x:Name="SendButton" Content="🚀 分发执行" 
                        Margin="0,10,0,0" Padding="10,12"
                        Background="#007AFF" Foreground="#ffffff" 
                        BorderThickness="0" FontWeight="SemiBold"
                        Cursor="Hand" Click="SendButton_Click">
                    <Button.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Border>

        </Grid>
    </Grid>
</UserControl>
