<Window x:Class="WebViewHub.Controls.ClearCacheDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="清除缓存" Height="300" Width="350"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        ResizeMode="NoResize">
    <Window.Resources>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#007AFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#f0f0f5"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#e5e5ea"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Background="#fdfdfd" CornerRadius="12" BorderBrush="#e5e5ea" BorderThickness="1" ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect Color="Black" Opacity="0.15" BlurRadius="20" ShadowDepth="5"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="50"/>
            </Grid.RowDefinitions>

            <!-- 标题 -->
            <StackPanel Grid.Row="0" Margin="20,20,20,10" HorizontalAlignment="Center">
                <TextBlock Text="清除浏览数据" FontSize="16" FontWeight="SemiBold" Foreground="#1c1c1e" TextAlignment="Center"/>
                <TextBlock Text="选择要清除的数据类型" FontSize="12" Foreground="#8e8e93" TextAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- 选项区 -->
            <StackPanel Grid.Row="1" Margin="25,10,25,10">
                <CheckBox x:Name="ChkCache" Content="缓存文件" IsChecked="True" Margin="0,5" FontSize="14" Foreground="#1c1c1e"/>
                <CheckBox x:Name="ChkCookie" Content="Cookies" IsChecked="True" Margin="0,5" FontSize="14" Foreground="#1c1c1e"/>
                <CheckBox x:Name="ChkHistory" Content="浏览历史记录" IsChecked="True" Margin="0,5" FontSize="14" Foreground="#1c1c1e"/>
                <CheckBox x:Name="ChkFormData" Content="表单自动填充数据" IsChecked="True" Margin="0,5" FontSize="14" Foreground="#1c1c1e"/>
                
                <TextBlock Text="提示：清除数据后将自动刷新页面" FontSize="11" Foreground="#8e8e93" Margin="0,15,0,0" TextWrapping="Wrap"/>
            </StackPanel>

            <!-- 按钮组 -->
            <Border Grid.Row="2" BorderBrush="#e5e5ea" BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="1"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="取消" Style="{StaticResource ActionButton}" Foreground="#8e8e93" Click="BtnCancel_Click"/>
                    <Border Grid.Column="1" Background="#e5e5ea"/>
                    <Button Grid.Column="2" Content="清除" Style="{StaticResource ActionButton}" FontWeight="SemiBold" Foreground="#FF3B30" Click="BtnOk_Click"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
